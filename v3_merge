# ================== FILE MAP ==================
def safetensor_files(path):
    return sorted([os.path.join(path, f) for f in os.listdir(path) if f.endswith(".safetensors")])

def build_map(files):
    mp = {}
    for file in files:
        with safe_open(file, framework="pt", device="cpu") as f:
            for k in f.keys():
                mp[k] = file
    return mp

base_map   = build_map(safetensor_files(base_dir))
anchor_map = build_map(safetensor_files(anchor_dir))
coder_map  = build_map(safetensor_files(coder_dir))

def get_tensor(mp, key):
    file = mp.get(key)
    if file is None:
        return None
    with safe_open(file, framework="pt", device="cpu") as f:
        return f.get_tensor(key)

# ================== HELPERS ==================
def get_layer_idx(key):
    parts = key.split(".")
    for i, p in enumerate(parts):
        if p == "layers" and i+1 < len(parts) and parts[i+1].isdigit():
            return int(parts[i+1])
    return None

def coder_key(key, idx):
    return key.replace(f".layers.{idx}.", f".layers.{idx+8}.")

def get_weights(i):
    if i < 14: return 0.22, 0.43, 0.35
    elif i < 28: return 0.18, 0.40, 0.42
    else: return 0.15, 0.37, 0.48

# ================== EXPERT FUSION ==================
def fuse_experts(tb, tc, alpha=0.7):
    # flatten
    b = tb.view(-1)
    c = tc.view(-1)

    sim = F.cosine_similarity(b, c, dim=0)

    if sim > 0.5:
        return (alpha * tc + (1 - alpha) * tb).to(torch.bfloat16)
    else:
        return tc.to(torch.bfloat16)

# ================== STREAM MERGE ==================
print("\n🚀 Streaming merge with expert fusion...")

shard = {}
shard_idx = 1
bytes_count = 0
MAX_BYTES = 9_000_000_000

weight_map = {}
matched = skipped = experts = 0

for key in base_map.keys():

    tb = get_tensor(base_map, key).to(torch.bfloat16)
    idx = get_layer_idx(key)

    if idx is None:
        ta = get_tensor(anchor_map, key)
        if ta is not None and ta.shape == tb.shape:
            merged = (0.5 * ta.to(torch.bfloat16) + 0.5 * tb)
            matched += 1
        else:
            merged = tb
            skipped += 1

    else:
        wa, wb, wc = get_weights(idx)
        ck = coder_key(key, idx)

        ta = get_tensor(anchor_map, key)
        tc = get_tensor(coder_map, ck)

        has_a = ta is not None and ta.shape == tb.shape
        has_c = tc is not None and tc.shape == tb.shape

        if "experts." in key:
            experts += 1

            if has_c:
                merged = fuse_experts(tb, tc)
                matched += 1
            else:
                merged = tb
                skipped += 1

        elif has_a and has_c:
            merged = (
                wa * ta.to(torch.bfloat16) +
                wb * tb +
                wc * tc.to(torch.bfloat16)
            )
            matched += 1

        elif has_a:
            total = wa + wb
            merged = (
                (wa/total) * ta.to(torch.bfloat16) +
                (wb/total) * tb
            )
            matched += 1

        else:
            merged = tb
            skipped += 1

    shard[key] = merged
    bytes_count += merged.numel() * merged.element_size()

    # flush shard
    if bytes_count >= MAX_BYTES:
        name = f"model-{shard_idx:05d}-of-XXXXX.safetensors"
        path = os.path.join(OUT, name)

        save_file(shard, path)

        for k in shard.keys():
            weight_map[k] = name

        print(f"💾 Saved shard {shard_idx}")
        shard = {}
        bytes_count = 0
        shard_idx += 1
        gc.collect()

# final flush
